# --- Server ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# --- Database (postgres:16 via docker compose) ---
DATABASE_URL="postgresql://esperanza:esperanza@localhost:5432/esperanza?schema=public"

# --- Auth ---
JWT_SECRET="cambia-esto-en-produccion-por-favor"
JWT_EXPIRES_IN="8h"
BCRYPT_ROUNDS=10

# --- Brute force protection (RNF10) ---
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCK_MINUTES=10

# --- SMS adapter ---
# Valores soportados: stub | smartla
SMS_PROVIDER=stub
# Si SMS_PROVIDER=smartla, configurar URL base y token (Smart Messaging Gateway).
# Doc: https://api.smartla.net/smart-messaging-gw/doc/index.html
SMS_API_URL=https://api.smartla.net/smart-messaging-gw/notification
SMS_API_TOKEN=
# Código numérico del país por defecto para normalizar teléfonos sin prefijo (Guatemala = 502).
SMS_COUNTRY_ID=502

# --- CORS ---
CORS_ORIGIN=http://localhost:5173,http://localhost:4173
