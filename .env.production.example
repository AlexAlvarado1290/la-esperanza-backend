# Variables de producción para docker-compose.prod.yml
# Copiar como ".env" en el VPS junto al compose (mismo directorio).
#   cp .env.production.example .env
# Después rellenar los valores REALES (no usar los placeholders).

# --- Dominio público y HTTPS ---
# Subdominio DuckDNS que apunta al VPS.
DOMAIN=comunidad-esperanza.duckdns.org
# Correo donde Let's Encrypt avisa si el certificado va a vencer.
LE_EMAIL=alex1290ja@gmail.com

# --- Base de datos ---
# Generar con: openssl rand -base64 32
POSTGRES_PASSWORD=cambiar-por-uno-aleatorio-de-32-chars

# --- Auth ---
# Generar con: openssl rand -hex 48
JWT_SECRET=cambiar-por-uno-aleatorio-de-96-chars-de-hex

# --- SMS Smartla ---
# Token del portal Smartla. ROTAR antes de hacer pública la URL si quedó expuesto.
SMS_PROVIDER=smartla
SMS_API_URL=https://api.smartla.net/smart-messaging-gw/notification
SMS_API_TOKEN=token-real-de-smartla
SMS_COUNTRY_ID=502
